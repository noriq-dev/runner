# Example COMMITTED per-repo marker for the Noriq Runner.
#
# `noriq-runner init-project` writes one of these for you, from inside the repo — this
# file is the annotated reference for everything it does not ask about.
#
# Copy to `.noriq/project.toml` at the root of a repo you want the Runner to work.
# UNLIKE runner.toml (machine-local), this file IS committed — it travels with the
# repo and is team-shareable. It carries no secrets. Validated against
# @noriq-dev/shared's ProjectManifest when the daemon discovers it.

# Committed, portable project identifier (1–8 chars). Resolved to a prj_… id per
# configured server at registration, so the checkout stays portable across Noriq
# instances and forks without editing this file. Must match a project KEY you can
# reach on the server (the key you see in the dashboard, e.g. ACME).
key = "ACME"

# Optional: lock this repo's work to one BOARD within the project (RUN-71) — the same
# idea as `key`, one level down. A project can host several repos; without this, every
# task this repo's agents create lands on the project's default board. A board NAME
# (matched case-insensitively), not an id, for the same reason `key` is not a prj_… id:
# ids are server-local and this file is committed. A name the server can't resolve is
# shown as unresolved in the dashboard and simply doesn't bind — the repo stays fully
# dispatchable. A landing default, not a fence: the dispatch form filters its anchor
# list to this board, and an agent explicitly told another board is not blocked.
# board = "Runner"

# Default agent driver for this repo. Omit (or null) to use the runner's default.
# One of: "claude" | "codex".
tool = "claude"

# The repo's main branch, if the daemon should reference it. Optional.
defaultBranch = "main"

# ── Default model + reasoning effort, per kind (RUN-33) ──────────────────────
# Optional, and per KIND on purpose: that is where the difference actually lives.
# A scope run is exploration and judgment, a build is execution, a verify is
# adversarial reasoning — one repo-wide value gets at least one of them wrong.
# Say it once here instead of relying on whoever dispatches to remember.
#
# Precedence, most specific first:
#   the dispatch (a human chose, for that run)
#     → these defaults (this repo, this kind)
#       → whatever the tool itself defaults to
#
# Both fields are optional and independent — wanting a higher effort while
# inheriting the tool's model is perfectly normal, and so is the reverse.
#
#   model  — the vendor's own name, passed through. Deliberately not validated
#            against a list: model names change constantly, and a stale allowlist
#            would reject one your CLI supports fine. A wrong name fails fast.
#   effort — "low" | "medium" | "high" | "xhigh" | "max". Tool-agnostic INTENT;
#            each driver maps it. Codex's scale tops out at its own "high", so
#            "xhigh"/"max" clamp there rather than erroring mid-run.
#
# [defaults.scope]
# model = "claude-opus-4-8"    # exploration + judgment: worth the strong model
# effort = "high"
#
# [defaults.build]
# model = "claude-sonnet-5"    # execution against an approved task
# effort = "medium"
#
# [defaults.verify]
# effort = "xhigh"             # adversarial reasoning; inherit the tool's model

# ── The verify stage: a CHOICE (RUN-61) ──────────────────────────────────────
# What gates a BUILD run after its agent exits clean, decided by what this
# section contains:
#
#   omit [verify] entirely  → no verify stage. The diff still lands as a review
#                             diff on its branch — a human is the gate.
#   cmd = "…"               → the deterministic floor: the daemon runs it (zero
#                             tokens) in the Run's worktree; non-zero exit or
#                             timeout GATES the run, and the output goes back to
#                             the live agent to fix (bounded, K=2).
#   [verify.agent]          → the inline reviewer: a FRESH agent — never the one
#                             that wrote the code — reviews the diff read-only
#                             against the task intent and files a verdict; a FAIL
#                             report is handed back to the builder to fix, then a
#                             fresh reviewer looks again (bounded by maxRounds).
#   both                    → floor first (cheap screen), then the reviewer.
#
# A [verify] section with NEITHER is a config error, refused at parse — silence
# must not read as a gate that isn't there.
#
# Put tsc in `cmd`: vitest/esbuild do NOT catch type errors.
[verify]
cmd = "npm run typecheck && npm test"
#
# [verify.agent]                 # the inline reviewer (all fields optional)
# tool = "codex"                 # review on a DIFFERENT driver than the builder (RUN-70) —
#                                # the strongest form of the reviewer's independence: another
#                                # vendor's model judging the work. Blank = the run's driver.
#                                # A tool with no driver on the machine FAILS the gate rather
#                                # than silently reviewing with the builder's own vendor.
# model = "claude-opus-4-8"      # adversarial review is where a STRONGER model than the
#                                # builder's earns its cost. Blank = [defaults.verify], then
#                                # the driver's own default — EXCEPT when `tool` is set: model
#                                # names are vendor-specific, so naming a tool severs the
#                                # [defaults.verify] fallback (name the model here instead).
# effort = "high"                # tool-agnostic intent; falls through regardless of `tool`.
# maxRounds = 2                  # FAIL → fix → re-review rounds before the run stops and a
#                                # human picks it up. 0 = one review, no hand-back.
#
# The reviewer runs under the verify permission profile (read-only, below) on the build's
# worktree, under the run's budget, and holds NO Noriq credential — its whole output is its
# report; the daemon parses the verdict and posts the findings. With [land], the reviewer
# judges intent BEFORE landing; `cmd` still re-runs on the REBASED result (see below).
# timeoutSeconds = 600   # default 600; null = the built-in default
#
# WHICH SHELL `cmd` RUNS UNDER (RUN-42)
# Unset = the platform's own: `sh` on macOS/Linux, **cmd.exe on Windows**.
#
# That matters because THIS FILE IS COMMITTED: `cmd` travels to teammates on other
# operating systems. `&&` means the same thing in both shells, so the common
# `npm run typecheck && npm test` above is portable — but by luck, not design.
# These are not portable to cmd.exe:
#
#   FOO=1 npm test          # env prefix — sh only
#   npm test 2>&1 | tee f   # redirection/pipes differ
#   npx tsc src/**/*.ts     # globbing is the shell's job on sh, the app's on Windows
#   echo "$HOME"            # $VAR vs %VAR%
#
# If your verify command needs any of that on a mixed-OS team, pin a shell and get
# one behaviour everywhere. Git for Windows ships bash, and this daemon already
# requires git — so `bash` is a safe pin in practice:
#
# shell = "bash"
#
# Not the default, because a pin that turns out to be absent fails the gate outright,
# which is worse than cmd.exe handling the common case correctly.

# ── Auto-landing (opt-in) ────────────────────────────────────────────────────
# Where a passing build's diff goes, so you stop approving every run by hand. The
# daemon rebases the run onto `branch`, RE-RUNS [verify] on the rebased result, then
# fast-forwards it in and reaps the run's worktree/branch. Work accumulates on one
# integration branch; you merge it onward into main on your own schedule, reviewing a
# batch instead of clicking through runs.
#
# Verify runs AFTER the rebase on purpose: two runs can each be green at their own fork
# point and broken together — a gate that never sees the combination can't catch it.
#
# The daemon never MERGES into your protected branch — it asks. By default it never pushes
# either, so agent work reaches your disk and nowhere else; `autoPush` below opts it into
# publishing this one branch, and `mergeTarget` then opens a merge request rather than
# merging. The human boundary is approving that merge. See THREAT-MODEL.md.
#
# ⚠️ `branch` has no default and is never inferred. Point it at something push-triggered,
# auto-deploying, or watched by CI and you have handed agents production. Omit this whole
# section and nothing auto-lands — every diff waits on its own branch for you.
# [land]
# branch = "noriq/integration"  # may template <planKey> — "noriq/plan-<planKey>" gives each plan
#                               # its own working branch, which is what makes a merge request mean
#                               # something. A one-off dispatch (no plan) strips it → "noriq/plan".
# onlyWhenVerifyPasses = true   # false = an unverified diff reaches `branch`. Allowed, never assumed.
# resolveConflicts = true       # let the build agent fix MECHANICAL rebase conflicts;
#                               # anything needing a decision still bails to a human.
# allowedBranches = ["feature/**", "wip/*"]
#                               # what a DISPATCH may override `branch` with (globs). OMIT → no
#                               # override: `branch` is the only place runs land here. That default
#                               # is deliberate — otherwise adding this feature would silently make
#                               # every repo writable at `main` by anyone who can dispatch. You and
#                               # whoever clicks dispatch are not always the same person.
# mergeTarget = "main"          # open a merge request from `branch` to this, when the PLAN those
#                               # runs belong to is finished — so a human reviews one coherent
#                               # plan's worth of work, not a click per run. Needs autoPush (a PR
#                               # can't exist without the branch being pushed) and `gh` on PATH.
#                               # The daemon opens it AS YOU. Omit → no merge requests.
#                               # Pair with a per-plan branch: branch = "noriq/plan-<planKey>"
# autoPush = false              # push `branch` to its remote after a landing. DEFAULT FALSE, and
#                               # think before flipping it: with it off, nothing an agent writes
#                               # leaves this machine, and `git log origin/main..main` is your
#                               # "what did the agents do while I wasn't looking?" check. On, an
#                               # agent's diff reaches whatever watches that branch — CI, or a
#                               # deploy. The daemon pushes ONE branch, never --force. See
#                               # THREAT-MODEL.md.

# ── Per-kind permission profiles ─────────────────────────────────────────────
# The security floor per Run kind. Defaults (if omitted) are already safe: scope
# and verify are READ-ONLY, build gets worktree WRITE. No agent ever gets push
# credentials — that's enforced by the daemon and is not expressible here. (Still
# true with [land].autoPush: the DAEMON pushes, after the gate, on the branch the
# gate passed. A build agent running `git push` in its worktree has no credentials
# and no way to get them.)
#   write   : may the agent edit files in its worktree?
#   network : "restricted" (default) | "none" | "full" — the egress you INTEND this
#             kind to have. DECLARED, NOT ENFORCED: no driver reads this key today,
#             so an agent gets whatever egress the daemon process has, whatever you
#             write here. Record the intent — it is what makes enforcement adoptable
#             when the runner can isolate a run at the network layer — but do not
#             mistake "none" for a firewall. It is not one yet.
#   allow   : extra allowlist rules handed to the driver, e.g. "Bash(npm test:*)".
#             Build needs its bash allowlist here — bare `Bash` is never granted
#             unless you opt the kind into `auto` (below). ENFORCED on Claude
#             (allowedTools); codex gates by sandbox LEVEL, not per command, so
#             these rules do not narrow a codex run.
#   deny    : explicit deny rules. On Claude they outrank everything, INCLUDING auto.
#             On codex they bind nothing, for the same reason `allow` does not — a
#             denied command still runs there. See `mapSandbox` in drivers/codex.ts.
#   auto    : opt this kind into the driver's own AUTO mode (RUN-68) — Claude's
#             bypass-permissions / codex's unsandboxed full access — instead of the
#             curated allowlist. Default false, and the default is the floor; this
#             is the per-kind trust escape hatch for repos the allowlist fits badly.
#
#             What auto does NOT loosen, by design:
#               - `write` survives it: a read-only kind stays read-only (edit-tool
#                 denials on Claude; codex keeps the read-only sandbox — its sandbox
#                 is its only enforcement, so codex auto only changes write kinds).
#               - `deny` still binds.
#               - Push credentials (absent from the env) and the per-kind Noriq tool
#                 floor (enforced by the server's own tool registration) hold regardless.
#             What it DOES give up: the bash allowlist, and — for a write kind — the
#             sandbox confining writes to the worktree. On Claude, bash can also mutate
#             files, so verify-with-auto weakens "the reviewer never edits" to the
#             edit-tools layer. Committed file, deliberate choice. See THREAT-MODEL.md.
#
# [permissions.build]
# auto = true
[permissions.scope]
write = false
network = "restricted"

# DEP BOOTSTRAP (RUN-56): each Run gets a FRESH worktree, and a fresh worktree has no
# node_modules — without an install rule, `npm test` is allowed but exits 127 (`tsc:
# command not found`), so the verify gate can never go green for ANY run on the repo.
# Allowlist the ecosystem's PINNED install, not its open-ended one:
#   npm ci      — installs exactly the lockfile (integrity-hashed), refuses on drift,
#                 never edits package.json/lockfile. The agent chooses WHEN, never WHICH.
#   npm install — can add arbitrary packages and rewrite the lockfile. Grant it to build
#                 only if agents changing dependencies is work you actually dispatch.
[permissions.build]
write = true
network = "restricted"
allow = ["Bash(npm ci:*)", "Bash(npm test:*)", "Bash(npm run build:*)", "Bash(npx tsc:*)"]

[permissions.verify]
write = false
network = "restricted"
# Verify usually inherits deps from the build worktree it reviews, but a STANDALONE
# verify run starts fresh too. Exact `Bash(npm ci)` (no `:*`) is the safe grant: it
# cannot touch tracked files, so "executes but never edits" holds even on a driver
# whose bash is not confined by the write axis. Never put `npm install` here.
# allow = ["Bash(npm ci)", "Bash(npm test:*)"]
