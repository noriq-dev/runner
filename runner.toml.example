# Example machine config for the Noriq Runner daemon.
# Copy to ~/.noriq/runner.toml and edit. Validated against @noriq-dev/shared's
# RunnerConfig on startup. This file is machine-local — never commit your real one
# (the repo .gitignore already excludes runner.toml).

# Human label for this runner, shown in the dashboard's Runners panel.
label = "device01"

# The Noriq server (control plane) this runner dials.
server = "https://noriq.example"

# Directories walked to discover repos (a .noriq/project.toml marker). No central
# list — the daemon finds markers under these roots.
scanRoots = ["/home/you/code"]

# Max concurrent Runs (→ Runner.capabilities.maxConcurrency). Default 1.
concurrency = 2

# Optional: pin the installed drivers this runner advertises. Omit to auto-detect.
# tools = ["claude", "codex"]

# Default budget ceilings applied to Runs that don't carry their own.
[budget]
# maxTokens = 500000
# maxUsd = 5
# maxDurationSeconds = 1800

# Staying current (RUN-37). Machine-local on purpose: updating the daemon is a
# property of THIS BOX, not of a repo — a repo must never be able to update the
# daemon supervising it.
[update]
# Check whether this runner is behind, and say so in the log. A public GET against
# the runner's own repo (package.json on main). Nothing is downloaded, nothing is
# replaced, and Noriq is not involved.
check = true
checkIntervalHours = 24
# There is deliberately no `apply` key. The daemon does not replace its own
# executable: it holds your OAuth token, spawns agents at a permission floor it
# chooses, and with [land] can write your branches — so whoever controls the version
# feed would control all of that, unattended, on every opted-in box. Run
# `noriq-runner update` to check, and `npm i -g @noriq-dev/runner@latest` to update.
# See THREAT-MODEL.md.
