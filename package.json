{
  "name": "@noriq-dev/runner",
  "version": "0.10.1",
  "description": "Noriq Runner — a local daemon that connects to Noriq, spawns and supervises coding-agent processes (Claude/Codex), and streams status back. The execution plane for dispatching tasks/plans to agents from the dashboard.",
  "license": "MIT",
  "type": "module",
  "keywords": ["noriq", "agents", "claude", "codex", "coding-agent", "daemon", "cli"],
  "bin": {
    "noriq-runner": "./dist/cli.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "vendor:shared": "node scripts/vendor-shared.mjs",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "smol-toml": "^1.3.1",
    "ws": "^8.21.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@noriq-dev/shared": "file:./vendor/noriq-shared",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noriq-dev/runner.git"
  },
  "bugs": {
    "url": "https://github.com/noriq-dev/runner/issues"
  },
  "homepage": "https://github.com/noriq-dev/runner#readme"
}
